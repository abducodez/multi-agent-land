# Copy to .env and fill in your values.
# With no live binding configured (neither OPENAI_API_KEY nor MODAL_WORKSPACE)
# the app runs on a deterministic local stub — fully offline, no network.

# Required for live model inference via a generic OpenAI-compatible key
OPENAI_API_KEY=sk-...

# Optional: point at any OpenAI-compatible endpoint
# Examples:
#   Together AI:  https://api.together.xyz/v1
#   Groq:         https://api.groq.com/openai/v1
#   Ollama local: http://localhost:11434/v1
#   NVIDIA NIM:   https://integrate.api.nvidia.com/v1
OPENAI_BASE_URL=

# Fallback model name — used when a profile-specific var below is unset.
MODEL_NAME=gpt-4o-mini

# Per-agent model routing (ADR-0010). Each agent's manifest picks a logical
# profile; these map a profile to a concrete small model. They override the
# defaults in config/models.yaml. Every model should be <=32B; tiny is <=4B.
#   MODEL_TINY=qwen2.5-3b-instruct
#   MODEL_FAST=qwen2.5-7b-instruct
#   MODEL_BALANCED=qwen2.5-14b-instruct
#   MODEL_STRONG=qwen2.5-32b-instruct

# LiteLLM gateway → models served on Modal (ADR-0015). Setting MODAL_WORKSPACE
# activates the live path: config/models.yaml templates each profile's endpoint
# URL as https://${MODAL_WORKSPACE}--<endpoint>.modal.run/v1 (so the workspace is
# never hard-coded), routes through LiteLLM, and meters real per-call cost into
# the Governor's hourly_budget_usd. MODAL_LLM_KEY is the endpoint key — a
# self-served vLLM endpoint accepts any token (default "EMPTY").
#   MODAL_WORKSPACE=your-modal-workspace
#   MODAL_LLM_KEY=EMPTY
# Alternatively, point a single OpenAI-compatible base URL (also activates live):
#   MODAL_LLM_BASE_URL=https://your-workspace--gemma-4-12b.modal.run/v1
MODAL_WORKSPACE=
MODAL_LLM_KEY=
MODAL_LLM_BASE_URL=

# Durable event store backend (ADR-0014). When unset, the system uses the
# in-memory ledger (fully offline). When set, the append-only ledger is persisted
# through SQLAlchemy. Neon (managed Postgres) form:
#   DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/DB?sslmode=require
# A local SQLite URL also works (e.g. for trying the backend without a server):
#   DATABASE_URL=sqlite:///runs/events.db
DATABASE_URL=

# Set to 1 to activate <=4B Tiny Titan profile
TINY_TITAN_MODE=0

# Gradio server port (auto-detects a free port in 7960-8059 if unset)
GRADIO_SERVER_PORT=
